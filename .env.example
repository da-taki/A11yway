# Copy this file to `.env` for local optional configuration.
# Never commit a real `.env` file or any real API key.
#
# Groq is optional. A11yway's deterministic audits work without any key.
#
# Future AI scout mode should only suggest likely workflows and risks.
# Deterministic checks must verify findings before reports call them
# confirmed.
#
# Use A11yway only on public pages or pages where permission was granted.

A11YWAY_AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
A11YWAY_AI_SCOUT_ENABLED=false
A11YWAY_REQUIRE_PERMISSION_NOTICE=true
A11YWAY_AI_SCOUT_MODE=suggest_only
